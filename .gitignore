# ===================================================================
# JAVA / SPRING BOOT EXCLUSIONS
# ===================================================================
target/
*.class
.mvn/
mvnw
mvnw.cmd

# ===================================================================
# REACT / NODE.JS EXCLUSIONS (NEW)
# ===================================================================
# Never upload node_modules! It can easily be re-downloaded with 'npm install'
node_modules/

# Ignore local frontend build output production directories
dist/
build/

# Ignore local environment override files containing user tokens
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore the background npm crash debug logs we ran into earlier
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===================================================================
# GLOBAL IDE & SYSTEM EXCLUSIONS
# ===================================================================
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
